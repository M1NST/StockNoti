# Discord webhook URL for sending daily reports.
DISCORD_WEBHOOK_URL=

# Discord bot token for slash commands. Keep this secret.
DISCORD_BOT_TOKEN=

# Optional: guild/server id for instant slash-command sync while testing.
DISCORD_GUILD_ID=

# Optional: channel id for the bot's automatic daily report.
DISCORD_DAILY_CHANNEL_ID=
STOCKNOTI_DAILY_ENABLED=false
STOCKNOTI_DAILY_TIME=08:30
STOCKNOTI_TIMEZONE=Asia/Bangkok

# Optional free-tier API keys. The app still works without these by using yfinance.
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Optional defaults.
STOCKNOTI_CONFIG=config/watchlist.yaml
STOCKNOTI_REGION=US
